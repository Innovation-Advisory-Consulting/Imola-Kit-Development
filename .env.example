# App
VITE_APP_NAME=Imola Kit
VITE_APP_URL=
VITE_LOG_LEVEL=
VITE_AUTH_STRATEGY=NONE

# Auth0 (if using AUTH0 strategy)
# VITE_AUTH0_DOMAIN=
# VITE_AUTH0_CLIENT_ID=
# VITE_AUTH0_CALLBACK_URL=

# Azure AD / Microsoft Entra ID (if using AZURE_AD strategy)
# VITE_AZURE_CLIENT_ID=
# VITE_AZURE_TENANT_ID=
# VITE_AZURE_ORG_URL=

# Clerk (if using CLERK strategy)
# VITE_CLERK_PUBLISHABLE_KEY=

# Supabase (if using SUPABASE strategy)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# API Backend
# VITE_API_BASE_URL=http://localhost:8080/api

# Azure Document Intelligence
# VITE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<resource>.cognitiveservices.azure.com
# VITE_DOCUMENT_INTELLIGENCE_KEY=

# Azure OpenAI
# VITE_AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# VITE_AZURE_OPENAI_KEY=
# VITE_AZURE_OPENAI_DEPLOYMENT=gpt-4o
# VITE_AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Mapbox (optional)
VITE_MAPBOX_API_KEY=

# Google Tag Manager (optional)
VITE_GOOGLE_TAG_MANAGER_ID=
